# ---------------------------------------------------------------------------
# nextnano++ per-machine paths  --  EXAMPLE / TEMPLATE (safe to commit)
#
# Copy this file to  paths.local.yaml  (same directory) on EACH machine and
# replace the placeholders with the real paths for THAT machine:
#
#   Windows:  copy config\paths.local.yaml.example config\paths.local.yaml
#
# paths.local.yaml is gitignored and must never be committed -- it is
# machine-specific and the license points at a licensed asset. A `git pull`
# will never touch or overwrite it.
#
# Use forward slashes (they work on Windows). Environment variables
# (e.g. ${USERPROFILE}) and a leading ~ are expanded.
# ---------------------------------------------------------------------------

nextnano++:
  exe: "PATH_TO_NEXTNANO_EXECUTABLE"
  database: "PATH_TO_NEXTNANO_DATABASE"
  license: "PATH_TO_NEXTNANO_LICENSE"
  outputdirectory: "PATH_TO_LOCAL_OUTPUT_DIRECTORY"
  threads: 4
