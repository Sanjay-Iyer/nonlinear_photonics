# Smoke test 3B: 3D GaAs cuboid -- Standard-dimensionality check.
#
# Purpose: prove that the licensed nextnano++ (Evaluation or Standard) can
# execute a THREE-dimensional domain. The Free edition supports only 1D, so a
# successful 3D run confirms a licensed dimensional capability. It does not by
# itself distinguish Evaluation from Standard -- but since the work laptop uses
# License_nnp.lic from the Standard install, a pass validates the Standard
# workflow. Coarse grid on purpose: this is an execution + dimensionality
# check, not a converged physical model.
#
# Calculation: one confined Gamma electron state (single-band effective mass) --
# the lightest solve that unambiguously exercises the 3D Schroedinger machinery
# and writes normal output. Homogeneous GaAs: no alloy interfaces, no doping,
# no bias, no strain, no piezoelectricity, no optics, no current, no k.p, no
# self-consistency.
#
# VALIDATION: the FULL syntax of this deck was checked at home against the Free
# nextnano++ 3.0.0 parser (2026.7 package) with --parse and --structure. It
# parses cleanly and the solver builds the 3D grid (5 x 5 x 5 = 125 points,
# x,y,z in [0,8]) before stopping on the Free 1D-only gate ("This version of
# nextnano++ does not allow running 2D simulations" -- generic message). So the
# 3D-specific syntax (simulate3D{}, ygrid{}, zgrid{}, cuboid{}) is confirmed
# valid; only the licensed 3D *execution* remains for the work laptop (Standard).

global{
    simulate3D{}
    crystal_zb{ x_hkl = [1, 0, 0]  y_hkl = [0, 1, 0] }
    substrate{ name = "GaAs" }
    temperature = 300
}

grid{
    xgrid{
        line{ pos = 0.0  spacing = 2.0 }
        line{ pos = 8.0  spacing = 2.0 }
    }
    ygrid{
        line{ pos = 0.0  spacing = 2.0 }
        line{ pos = 8.0  spacing = 2.0 }
    }
    zgrid{
        line{ pos = 0.0  spacing = 2.0 }
        line{ pos = 8.0  spacing = 2.0 }
    }
}

# A charge-neutral fermi contact at zero bias. Required in every nextnano++
# deck; bias = 0.0 means NO applied bias -- it only supplies the electrostatic
# boundary reference, and run{} below invokes only the quantum solver.
contacts{
    fermi{
        name = box_contact
        bias = 0.0
    }
}

structure{
    # Homogeneous GaAs filling the 3D cuboid.
    region{
        cuboid{ x = [0.0, 8.0]  y = [0.0, 8.0]  z = [0.0, 8.0] }
        binary{ name = "GaAs" }
        contact{ name = box_contact }
    }
}

classical{
    Gamma{}
    HH{}
    output_bandedges{ averaged = no }
}

quantum{
    region{
        name = "box_3d"
        x = [0.0, 8.0]
        y = [0.0, 8.0]
        z = [0.0, 8.0]
        no_density = yes
        boundary{ x = dirichlet  y = dirichlet  z = dirichlet }
        Gamma{ num_ev = 1 }
        output_states{
            max_num       = 1
            envelopes     = yes
            probabilities = yes
        }
    }
}

run{
    quantum{}
}
