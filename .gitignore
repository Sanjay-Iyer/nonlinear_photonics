# Nested upstream aestimo checkout keeps its own history
/git/

# Prior-session scratch outputs at repo root
/output/
/hello_well/
/sample_1qw_barrierdope_ingaas/
/integrated_photonics_study_guide/
/.agents/

# Python / caches
__pycache__/
*.pyc
.ipynb_checkpoints/
mpl-cache/

# Large binary sim artifacts inside checkpoints are versioned deliberately;
# keep them, but drop stray temp files
*.tmp
*.log.lock

# ─── nextnano++ home-to-work workflow ───────────────────────────────────────
# Machine-specific local config: created by hand on each machine, never tracked.
# A `git pull` will never overwrite it.
nextnano/config/paths.local.yaml
# Raw solver output: ignore EVERYTHING under output/ (fields, meshes, logs, data,
# temp files all land here), but keep the empty dir in git via its .gitkeep.
# Scoping solver artifacts to output/ this way avoids broad repo-wide *.dat /
# *.log rules that would hide legitimate scientific files elsewhere -- e.g. the
# curated results under nextnano/results/ stay fully tracked.
nextnano/output/**
!nextnano/output/.gitkeep
# Any nextnano license file, anywhere -- licensed asset, must never be committed.
*.lic
# Python / test caches (also covered repo-wide above; repeated so this block is
# self-documenting for anyone reading only the nextnano workflow rules).
__pycache__/
*.pyc
.pytest_cache/
.ipynb_checkpoints/
