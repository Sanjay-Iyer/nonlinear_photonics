# Nested upstream aestimo checkout keeps its own history
/git/

# Prior-session scratch outputs at repo root
/output/
/hello_well/
/sample_1qw_barrierdope_ingaas/
/integrated_photonics_study_guide/
/.agents/

# Python / caches
__pycache__/
*.pyc
.ipynb_checkpoints/
mpl-cache/

# Large binary sim artifacts inside checkpoints are versioned deliberately;
# keep them, but drop stray temp files
*.tmp
*.log.lock

# ─── nextnano++ split-machine workflow ──────────────────────────────────────
# Machine-specific local config: created by hand on each machine, never tracked.
nextnano/config/paths.local.yaml
# Runtime solver results: ignore everything under output/, but keep the empty
# directory in git via its .gitkeep (the /** + negation pattern re-includes it).
nextnano/output/**
!nextnano/output/.gitkeep
# Any nextnano license file, anywhere -- licensed asset, must never be committed.
*.lic
# nextnano-generated solver artifacts (log / field / mesh / data), scoped to
# nextnano/ so these broad extensions don't hide valid scientific files
# elsewhere in the repo. Outputs normally land under output/ (already ignored);
# these catch stray files from a misconfigured run.
nextnano/**/*.log
nextnano/**/*.vtr
nextnano/**/*.fld
nextnano/**/*.dat
nextnano/**/*.coord
nextnano/**/*.avs*
# Python / test caches (also covered repo-wide above; repeated so this block is
# self-documenting for anyone reading only the nextnano workflow rules).
__pycache__/
*.pyc
.pytest_cache/
.ipynb_checkpoints/
